package com.projet.view;

import com.projet.controller.BatimentController;
import com.projet.model.Immeuble;
import com.projet.model.Revetement;
import javafx.collections.FXCollections;
import javafx.collections.ObservableList;
import javafx.geometry.Insets;
import javafx.scene.canvas.Canvas;
import javafx.scene.canvas.GraphicsContext;
import javafx.scene.control.*;
import javafx.scene.layout.BorderPane;
import javafx.scene.layout.VBox;
import javafx.scene.paint.Color;
import javafx.scene.text.Font;
import java.util.ArrayList;
import java.util.HashMap;
import java.util.List;
import java.util.Map;

public class BatimentView extends BorderPane {

    private BatimentController controller;
    private ObservableList<PieceGraphique> toutesLesPieces = FXCollections.observableArrayList();
    private List<Revetement> catalogue = new ArrayList<>();

    public BatimentView(Immeuble immeuble) {
        this.controller = new BatimentController(immeuble);

        this.catalogue = com.projet.GestionFichiers.chargerCatalogue("catalogue.txt");

        VBox zoneGauche = new VBox(7);
        zoneGauche.setPadding(new Insets(10));
        zoneGauche.setStyle("-fx-background-color: #f4f4f4; -fx-border-color: #cccccc; -fx-border-width: 0 1 0 0;");
        zoneGauche.setPrefWidth(310);

        TextField niveauInput = new TextField("0");
        Button btnVoirNiveau = new Button("Filtrer l'affichage");
        btnVoirNiveau.setStyle("-fx-background-color: #ff9800; -fx-text-fill: white;");

        TextField appartInput = new TextField("101");
        TextField idPieceInput = new TextField("1");
        TextField largeurInput = new TextField("4.0");
        TextField longueurInput = new TextField("5.0");
        TextField nbFenetresInput = new TextField("0");
        TextField nbPortesInput = new TextField("0");
        TextField xInput = new TextField("0.0");
        TextField yInput = new TextField("0.0");

        ComboBox<Revetement> comboSol = new ComboBox<>();
        ComboBox<Revetement> comboMur = new ComboBox<>();
        ComboBox<Revetement> comboPlafond = new ComboBox<>();

        for (Revetement r : catalogue) {
            if (r.isPourSol()) comboSol.getItems().add(r);
            if (r.isPourMur()) comboMur.getItems().add(r);
            if (r.isPourPlafond()) comboPlafond.getItems().add(r);
        }
        
        if (!comboSol.getItems().isEmpty()) comboSol.getSelectionModel().selectFirst();
        if (!comboMur.getItems().isEmpty()) comboMur.getSelectionModel().selectFirst();
        if (!comboPlafond.getItems().isEmpty()) comboPlafond.getSelectionModel().selectFirst();

        Button btnAjouter = new Button("Calculer Devis");
        btnAjouter.setStyle("-fx-background-color: #2ecc71; -fx-text-fill: white;");
        btnAjouter.setMaxWidth(Double.MAX_VALUE);

        Button btnSupprimer = new Button("Supprimer la pièce");
        btnSupprimer.setStyle("-fx-background-color: #e74c3c; -fx-text-fill: white;");
        btnSupprimer.setMaxWidth(Double.MAX_VALUE);

        zoneGauche.getChildren().addAll(
            new Label("Niveau / Étage :"), niveauInput, btnVoirNiveau, new Separator(),
            new Label("N° Appartement :"), appartInput,
            new Label("ID de la Pièce :"), idPieceInput,
            new Label("Position X (départ) :"), xInput,
            new Label("Position Y (départ) :"), yInput,
            new Label("Largeur (m) :"), largeurInput,
            new Label("Longueur (m) :"), longueurInput, 
            new Label("Nombre de Fenêtres :"), nbFenetresInput,
            new Label("Nombre de Portes :"), nbPortesInput, new Separator(),
            new Label("Revêtement SOL :"), comboSol,
            new Label("Revêtement MURS :"), comboMur,
            new Label("Revêtement PLAFOND :"), comboPlafond, new Separator(),
            btnAjouter,
            btnSupprimer
        );

        ScrollPane scrollGauche = new ScrollPane();
        scrollGauche.setContent(zoneGauche);
        scrollGauche.setFitToWidth(true);
        scrollGauche.setHbarPolicy(ScrollPane.ScrollBarPolicy.NEVER);
        this.setLeft(scrollGauche);

        VBox zoneCentre = new VBox(10);
        zoneCentre.setPadding(new Insets(10));
        Label titrePlan = new Label("PLAN DU NIVEAU : 0");

        Canvas canvas = new Canvas(500, 320);
        GraphicsContext gc = canvas.getGraphicsContext2D();
        initCanvas(gc);

        TextArea zoneDevis = new TextArea();
        zoneDevis.setEditable(false);
        zoneDevis.setPrefHeight(220);
        zoneDevis.setFont(Font.font("Courier New", 12));

        zoneCentre.getChildren().addAll(titrePlan, canvas, zoneDevis);
        
        ScrollPane scrollCentre = new ScrollPane();
        scrollCentre.setContent(zoneCentre);
        scrollCentre.setFitToWidth(true);
        this.setCenter(scrollCentre);

        btnVoirNiveau.setOnAction(event -> {
            try {
                int idNiveau = Integer.parseInt(niveauInput.getText().trim());
                titrePlan.setText("PLAN DU NIVEAU : " + idNiveau);
                redessinerPlanNiveau(gc, idNiveau);
            } catch (NumberFormatException e) {
                zoneDevis.setText("Erreur de format.");
            }
        });

        btnAjouter.setOnAction(event -> {
            try {
                int idNiveau = Integer.parseInt(niveauInput.getText().trim());
                int idAppart = Integer.parseInt(appartInput.getText().trim());
                int idPiece = Integer.parseInt(idPieceInput.getText().trim());
                double largeur = Double.parseDouble(largeurInput.getText().trim());
                double longueur = Double.parseDouble(longueurInput.getText().trim());
                double x = Double.parseDouble(xInput.getText().trim());
                double y = Double.parseDouble(yInput.getText().trim());

                if (largeur <= 0 || longueur <= 0) return;

                double surfaceCalculee = largeur * longueur;

                com.projet.model.Piece nouvellePiece = new com.projet.model.Piece(idPiece);

                com.projet.model.Sol solPiece = new com.projet.model.Sol(surfaceCalculee);
                solPiece.appliquerRevetement(comboSol.getValue());
                nouvellePiece.setSol(solPiece);

                com.projet.model.Plafond plafondPiece = new com.projet.model.Plafond(surfaceCalculee);
                plafondPiece.appliquerRevetement(comboPlafond.getValue());
                nouvellePiece.setPlafond(plafondPiece);

                com.projet.model.Coin c1 = new com.projet.model.Coin(1, x, y);
                com.projet.model.Coin c2 = new com.projet.model.Coin(2, x + largeur, y);
                com.projet.model.Coin c3 = new com.projet.model.Coin(3, x + largeur, y + longueur);
                com.projet.model.Coin c4 = new com.projet.model.Coin(4, x, y + longueur);
                
                com.projet.model.Mur m1 = new com.projet.model.Mur(1, c1, c2);
                com.projet.model.Mur m2 = new com.projet.model.Mur(2, c2, c3);
                com.projet.model.Mur m3 = new com.projet.model.Mur(3, c3, c4);
                com.projet.model.Mur m4 = new com.projet.model.Mur(4, c4, c1);

                m1.appliquerRevetement(comboMur.getValue());
                m2.appliquerRevetement(comboMur.getValue());
                m3.appliquerRevetement(comboMur.getValue());
                m4.appliquerRevetement(comboMur.getValue());

                int nbFenetres = Integer.parseInt(nbFenetresInput.getText().trim());
                int nbPortes = Integer.parseInt(nbPortesInput.getText().trim());

                for (int f = 0; f < nbFenetres; f++) {
                    m1.ajouterOuverture(new com.projet.model.Fenetre(f));
                }
                for (int p = 0; p < nbPortes; p++) {
                    m1.ajouterOuverture(new com.projet.model.Porte(p));
                }

                nouvellePiece.ajouterMur(m1);
                nouvellePiece.ajouterMur(m2);
                nouvellePiece.ajouterMur(m3);
                nouvellePiece.ajouterMur(m4);

                controller.enregistrerPieceDansModele(idNiveau, idAppart, nouvellePiece);

                toutesLesPieces.add(new PieceGraphique(idNiveau, idAppart, idPiece, x, y, largeur, longueur));

                double coutTotalImmeuble = controller.getBatiment().devisBatiment();

                StringBuilder detailDevis = new StringBuilder();
                for (com.projet.model.Revetement rev : catalogue) {
                    double surfaceTot = controller.getBatiment().surfaceRevetement(rev.getIdRevetement());
                    if (surfaceTot > 0) {
                        double coutRev = surfaceTot * rev.getPrixUnitaire();
                        detailDevis.append(String.format(" - %s : %.2f m² | %.2f €\n", rev.getDesignation(), surfaceTot, coutRev));
                    }
                }

                int totalFenetres = Integer.parseInt(nbFenetresInput.getText().trim());
                int totalPortes = Integer.parseInt(nbPortesInput.getText().trim());

                zoneDevis.setText(
                    "====================================================\n" +
                    "          DEVIS GENERAL MIS A JOUR                  \n" +
                    "====================================================\n" +
                    " COUT CUMULE DE TOUT L'IMMEUBLE   : " + String.format("%.2f", coutTotalImmeuble) + " €\n" +
                    "----------------------------------------------------\n" +
                    " MENUISERIES DE LA PIÈCE :\n" +
                    "  - Nombre de Fenêtre(s) : " + totalFenetres + "\n" +
                    "  - Nombre de Porte(s)   : " + totalPortes + "\n" +
                    "----------------------------------------------------\n" +
                    " DÉTAIL PAR REVÊTEMENT :\n" +
                    detailDevis.toString() +
                    "===================================================="
                );

                titrePlan.setText("PLAN DU NIVEAU : " + idNiveau);
                redessinerPlanNiveau(gc, idNiveau);

            } catch (NumberFormatException e) {
                zoneDevis.setText("Erreur : Entrée numérique incorrecte.");
            }
        });

        btnSupprimer.setOnAction(event -> {
            try {
                int idNiveau = Integer.parseInt(niveauInput.getText().trim());
                int idAppart = Integer.parseInt(appartInput.getText().trim());
                int idPiece = Integer.parseInt(idPieceInput.getText().trim());

                toutesLesPieces.removeIf(p -> p.idNiveau == idNiveau && p.idAppart == idAppart && p.idPiece == idPiece);

                controller.supprimerPieceDuModele(idNiveau, idAppart, idPiece);

                double coutTotal = controller.getBatiment().devisBatiment();
                StringBuilder detailDevis = new StringBuilder();
                for (com.projet.model.Revetement rev : catalogue) {
                    double surfaceTot = controller.getBatiment().surfaceRevetement(rev.getIdRevetement());
                    if (surfaceTot > 0) {
                        double coutRev = surfaceTot * rev.getPrixUnitaire();
                        detailDevis.append(String.format(" - %s : %.2f m² | %.2f €\n", rev.getDesignation(), surfaceTot, coutRev));
                    }
                }

                zoneDevis.setText(
                    "====================================================\n" +
                    "          DEVIS GENERAL MIS A JOUR                  \n" +
                    "====================================================\n" +
                    " COUT CUMULE DE TOUT L'IMMEUBLE   : " + String.format("%.2f", coutTotal) + " €\n" +
                    "----------------------------------------------------\n" +
                    " DÉTAIL PAR REVÊTEMENT :\n" +
                    detailDevis.toString() +
                    "===================================================="
                );

                redessinerPlanNiveau(gc, idNiveau);

            } catch (Exception e) {
                zoneDevis.setText("Erreur lors de la suppression de la pièce.");
            }
        });
    }

    private void initCanvas(GraphicsContext gc) {
        double h = gc.getCanvas().getHeight();
        double w = gc.getCanvas().getWidth();
        gc.setFill(Color.WHITE); 
        gc.fillRect(0, 0, w, h);
        gc.setStroke(Color.web("#eef0f2")); 
        gc.setLineWidth(0.5);
        for (int i = 0; i < w; i += 20) gc.strokeLine(i, 0, i, h);
        for (int j = 0; j < h; j += 20) gc.strokeLine(0, j, w, j);
    }

    private void redessinerPlanNiveau(GraphicsContext gc, int niveauActuel) {
        Map<Integer, List<PieceGraphique>> appartsDuNiveau = new HashMap<>();
        for (PieceGraphique pg : toutesLesPieces) {
            if (pg.idNiveau == niveauActuel) {
                appartsDuNiveau.computeIfAbsent(pg.idAppart, k -> new ArrayList<>()).add(pg);
            }
        }

        double maxCanvasHeight = 320;
        double maxCanvasWidth = 480;

        Map<Integer, double[]> limitesApparts = new HashMap<>();
        for (Map.Entry<Integer, List<PieceGraphique>> entry : appartsDuNiveau.entrySet()) {
            List<PieceGraphique> pieces = entry.getValue();
            double minX = Double.MAX_VALUE;
            double minY = Double.MAX_VALUE;
            double maxX = Double.MIN_VALUE;
            double maxY = Double.MIN_VALUE;

            for (PieceGraphique pg : pieces) {
                double px = pg.px * 15; 
                double py = pg.py * 15;
                double pw = pg.largeur * 15;
                double ph = pg.longueur * 15;

                if (px < minX) minX = px;
                if (py < minY) minY = py;
                if (px + pw > maxX) maxX = px + pw;
                if (py + ph > maxY) maxY = py + ph;
            }

            limitesApparts.put(entry.getKey(), new double[]{minX, minY, maxX, maxY});

            if (maxX + 50 > maxCanvasWidth) maxCanvasWidth = maxX + 50;
            if (maxY + 80 > maxCanvasHeight) maxCanvasHeight = maxY + 80;
        }

        Canvas canvasActuel = gc.getCanvas();
        canvasActuel.setHeight(maxCanvasHeight);
        canvasActuel.setWidth(maxCanvasWidth);

        initCanvas(gc);

        for (Map.Entry<Integer, List<PieceGraphique>> entry : appartsDuNiveau.entrySet()) {
            int idAppart = entry.getKey();
            double[] limites = limitesApparts.get(idAppart);
            
            double appX = limites[0] + 10;
            double appY = limites[1] + 25;
            double appW = limites[2] - limites[0] + 16;
            double appH = limites[3] - limites[1] + 22;

            if (appW < 100) appW = 100;

            gc.setStroke(Color.web("#e74c3c"));
            gc.setLineWidth(2.0);
            gc.strokeRect(appX, appY, appW, appH);

            gc.setFill(Color.web("#e74c3c"));
            gc.setFont(Font.font("Arial", 10));
            gc.fillText("Appart " + idAppart, appX + 6, appY + 14);

            for (PieceGraphique pg : entry.getValue()) {
                double pw = pg.largeur * 15;
                double ph = pg.longueur * 15;
                
                double positionPieceX = appX + 8 + (pg.px * 15) - limites[0];
                double positionPieceY = appY + 22 + (pg.py * 15) - limites[1];

                gc.setFill(Color.web("#d4e6f1"));
                gc.fillRect(positionPieceX, positionPieceY, pw, ph);

                gc.setStroke(Color.web("#2980b9"));
                gc.setLineWidth(1.0);
                gc.strokeRect(positionPieceX, positionPieceY, pw, ph);

                gc.setFill(Color.BLACK);
                gc.setFont(Font.font("Arial", 8));
                gc.fillText("P." + pg.idPiece, positionPieceX + 3, positionPieceY + 10);
            }
        }
    }

    public static class PieceGraphique {
        public int idNiveau, idAppart, idPiece; 
        public double px, py, largeur, longueur;
        public PieceGraphique(int nv, int ap, int pc, double x, double y, double lg, double lon) {
            this.idNiveau = nv; 
            this.idAppart = ap;
            this.idPiece = pc; 
            this.px = x;
            this.py = y;
            this.largeur = lg; 
            this.longueur = lon;
        }
    }
}