package com.projet.model;
public class Porte extends Ouverture {
    private int idPorte;
    private double largeur = 0.90;
    private double hauteur = 2.10;

    public Porte(int idPorte) { this.idPorte = idPorte; }
    public int getIdPorte() { return idPorte; }

    @Override
    public double surface() { return this.largeur * this.hauteur; }
}